{
  "expo": {
    "name": "Agile Label",
    "slug": "agile_label",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon_agilelabel.png",
    "scheme": "agilelabel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "cli": {
      "appVersionSource": "local"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "5",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "en",
        "CFBundleAllowMixedLocalizations": true,
        "NSPhotoLibraryAddUsageDescription": "Allow saving images to your photo library",
        "NSCameraUsageDescription": "Allow taking photos to add to datasets",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.micomia.agilelabel"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon_fg.png",
        "backgroundImage": "./assets/images/icon_bg.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA"
      ],
      "package": "com.watson404v.agile_label"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon_agilelabel.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "buildToolsVersion": "35.0.0"
          },
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "locales": {
      "ja": "./i18n/locales/ios-ja.json"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "163ab1cd-708b-452a-8f05-015a4ae6c098"
      }
    }
  }
}
