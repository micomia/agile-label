{
  "expo": {
    "name": "agile_label",
    "slug": "agile_label",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon_agilelabel.png",
    "scheme": "agilelabel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "画像をフォトライブラリに保存するために必要です",
        "NSCameraUsageDescription": "写真を撮影してデータセットに追加するために必要です",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.micomia.agilelabel"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA"
      ],
      "package": "com.watson404v.agile_label"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 31,
            "targetSdkVersion": 31,
            "buildToolsVersion": "31.0.0"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "163ab1cd-708b-452a-8f05-015a4ae6c098"
      }
    }
  }
}
